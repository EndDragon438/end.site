<!DOCTYPE html>
<html>
  {{ head }}
  <body>
    <!-- navbar div -->
    {{ header }}
    <div class="main_content" id="creation_page">
        <div class="creation-side">
          <h1 class="creation-title">{{ data: title }}</h1>
          <h3 class="creation-date">{{ data: date }}</h3>
          <h2 class="creation-subtitle" style="margin:0;"><a href="{{ data: link }}" target="blank">alternative link</a></h2>
          <p class="creation-image-desc">
            {{ data: text }}
          </p>
          {{ data: tags }}
        </div>
        <img class="creation-image" src="/creations/3d/resources/{{ data: file }}"/>
    </div>
    <!-- fixed footer here -->
    <footer>
      <p class="footer">{{ last_modified }}</p>
    </footer>
  </body>
</html>