<!DOCTYPE html>
<html lang="en">
    {{ head }}
    <body>
        {{ header }}
        <main>
            <img class="creation-image" src="/creations/3d/resources/{{ data: file }}"/>
            <div class="creation-side">
                <h1 class="creation-title">{{ data: title }}</h1>
                <p class="creation-date">{{ data: date }}</p>
                <p class="creation-subtitle" style="margin:0;"><a href="{{ data: link }}" target="blank">alternative link</a></p>
                <p class="creation-image-desc">
                    {{ data: text }}
                </p>
                {{ data: tags }}
            </div>
        </main>
        <footer>
            <p>{{ last_modified }}</p>
        </footer>
    </body>
</html>